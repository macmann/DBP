generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PageStatus {
  draft
  generating
  published
  failed
}

enum AssetType {
  logo
  screenshot
  image
  file
}

enum BuildJobStatus {
  queued
  running
  completed
  failed
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pages     Page[]
  assets    Asset[]
  buildJobs BuildJob[]
}

model Page {
  id               String     @id @default(cuid())
  projectId        String
  currentVersionId String?
  title            String
  slug             String
  publicSlug       String     @unique
  prompt           String?
  referenceLinks   Json?
  status           PageStatus @default(draft)
  content          String?
  lastError        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  publishedAt      DateTime?

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentVersion PageVersion?  @relation("CurrentPageVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions       PageVersion[] @relation("PageVersions")
  assets         Asset[]
  buildJobs      BuildJob[]

  @@unique([projectId, slug])
}

model Asset {
  id         String    @id @default(cuid())
  projectId  String
  pageId     String?
  type       AssetType
  sortOrder  Int       @default(0)
  fileName   String
  mimeType   String
  storageUrl String
  metadata   Json?
  createdAt  DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  page    Page?   @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([projectId, type])
  @@index([pageId, sortOrder])
}

model PageVersion {
  id                  String   @id @default(cuid())
  pageId              String
  versionNumber       Int
  instructionPrompt   String?
  generatedSchemaJson Json?
  notes               String?
  createdAt           DateTime @default(now())

  page            Page       @relation("PageVersions", fields: [pageId], references: [id], onDelete: Cascade)
  currentForPages Page[]     @relation("CurrentPageVersion")
  buildJobs       BuildJob[]

  @@unique([pageId, versionNumber])
}

model BuildJob {
  id           String         @id @default(cuid())
  projectId    String
  pageId       String?
  versionId    String?
  status       BuildJobStatus @default(queued)
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  page    Page?        @relation(fields: [pageId], references: [id], onDelete: SetNull)
  version PageVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
}
